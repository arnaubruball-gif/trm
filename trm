<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TRM – Technical Roof Management</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --blue:       #1e4d8c;
  --blue-dark:  #163a6b;
  --blue-light: #2563b0;
  --accent:     #1e4d8c;
  --text:       #27313D;
  --text-light: #5a6472;
  --border:     #dde3ea;
  --bg-light:   #f5f7fa;
  --white:      #ffffff;
  --nav-h:      80px;
}

html { scroll-behavior: smooth; }
body { font-family: 'Source Sans 3', sans-serif; color: var(--text); background: var(--white); overflow-x: hidden; font-size: 16px; line-height: 1.6; }

/* ─── NAV ─── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  height: var(--nav-h);
  background: var(--white);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40px;
}
.nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.nav-logo-box {
  background: var(--blue); color: white;
  font-size: 15px; font-weight: 700; letter-spacing: 0.5px;
  padding: 6px 10px; line-height: 1;
}
.nav-logo-text { font-size: 13px; font-weight: 600; color: var(--text); line-height: 1.2; }
.nav-logo-text small { display: block; font-weight: 400; color: var(--text-light); font-size: 11px; }
nav ul { list-style: none; display: flex; align-items: center; gap: 28px; }
nav ul li > a {
  font-size: 14px; color: var(--text); text-decoration: none; font-weight: 400;
  padding: 4px 0; border-bottom: 2px solid transparent;
  transition: color .2s, border-color .2s;
}
nav ul li > a:hover { color: var(--blue); border-bottom-color: var(--blue); }
.nav-dropdown { position: relative; }
.nav-dropdown > a::after { content: ' ▾'; font-size: 10px; }
.dropdown-menu {
  display: none; position: absolute; top: calc(100% + 16px); left: 0;
  background: white; border: 1px solid var(--border);
  box-shadow: 0 4px 20px rgba(0,0,0,.08);
  min-width: 200px; padding: 8px 0; z-index: 300;
}
.nav-dropdown:hover .dropdown-menu { display: block; }
.dropdown-menu a { display: block; padding: 8px 20px; font-size: 14px; color: var(--text); text-decoration: none; }
.dropdown-menu a:hover { background: var(--bg-light); color: var(--blue); }
.nav-cta {
  background: var(--blue); color: white !important;
  padding: 10px 20px !important; border: none !important;
  font-weight: 600 !important; font-size: 14px !important;
  transition: background .2s !important;
}
.nav-cta:hover { background: var(--blue-dark) !important; border-color: transparent !important; }
.nav-langs { display: flex; gap: 8px; }
.nav-langs a { font-size: 13px; color: var(--text-light); text-decoration: none; font-weight: 600; }
.nav-langs a.active { color: var(--blue); }

/* ─── HERO ─── */
#hero {
  margin-top: var(--nav-h);
  background: var(--white);
  display: grid; grid-template-columns: 1fr 1fr;
  min-height: 560px;
}
.hero-left {
  padding: 80px 60px 80px 80px;
  display: flex; flex-direction: column; justify-content: center;
}
.hero-left h1 {
  font-size: clamp(28px, 3.5vw, 46px);
  font-weight: 700; line-height: 1.15;
  color: var(--text); margin-bottom: 20px;
}
.hero-left p { font-size: 17px; color: var(--text-light); line-height: 1.7; margin-bottom: 36px; max-width: 460px; }
.hero-links { display: flex; flex-direction: column; gap: 0; }
.hero-link-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 0; border-bottom: 1px solid var(--border);
  text-decoration: none; color: var(--text);
  font-size: 15px; font-weight: 600;
  transition: color .2s;
}
.hero-link-item:first-child { border-top: 1px solid var(--border); }
.hero-link-item:hover { color: var(--blue); }
.hero-link-item .arrow { font-size: 18px; color: var(--blue); }
.hero-right {
  background: var(--bg-light);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; position: relative;
}
.hero-right img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ─── SECTION BASE ─── */
.section { padding: 80px 80px; max-width: 1280px; margin: 0 auto; }
.section-sm { padding: 60px 80px; max-width: 1280px; margin: 0 auto; }
.full-w { max-width: none; padding-left: 0; padding-right: 0; }

h2.section-title {
  font-size: clamp(22px, 2.5vw, 32px);
  font-weight: 700; color: var(--text); line-height: 1.2;
  margin-bottom: 20px;
}
.section-text { font-size: 16px; color: var(--text-light); line-height: 1.75; }
.btn-primary {
  display: inline-block; background: var(--blue); color: white;
  padding: 12px 28px; font-weight: 600; font-size: 15px;
  text-decoration: none; border: none; cursor: pointer;
  transition: background .2s;
}
.btn-primary:hover { background: var(--blue-dark); }
.btn-link {
  display: inline-flex; align-items: center; gap: 6px;
  color: var(--blue); font-weight: 600; font-size: 15px;
  text-decoration: none; border-bottom: 1px solid transparent;
  transition: border-color .2s;
}
.btn-link:hover { border-bottom-color: var(--blue); }
.btn-link::after { content: '→'; }

/* ─── INTRO ─── */
#intro {
  border-top: 1px solid var(--border);
  background: var(--white);
}
.intro-inner {
  max-width: 1280px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
  align-items: center; padding: 80px;
}
.intro-left h2 { margin-bottom: 20px; }
.intro-left p { margin-bottom: 16px; font-size: 16px; color: var(--text-light); line-height: 1.75; }
.intro-left .btn-primary { margin-top: 12px; }
.intro-right { position: relative; }
.intro-right img { width: 100%; display: block; }

/* ─── FEATURE BLOCKS (sensor / leak) ─── */
.feature-block {
  display: grid; grid-template-columns: 1fr 1fr;
  min-height: 480px;
}
.feature-block.reverse { direction: rtl; }
.feature-block.reverse > * { direction: ltr; }
.feat-img { overflow: hidden; }
.feat-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.feat-body {
  padding: 80px 70px;
  display: flex; flex-direction: column; justify-content: center;
  background: var(--white);
}
.feat-body.dark {
  background: #1a2e48;
}
.feat-body.dark h2,
.feat-body.dark h3 { color: white; }
.feat-body.dark p { color: rgba(255,255,255,.7); }
.feat-body.dark .btn-link { color: #7ab4e8; }
.feat-body.dark .feat-list li { color: rgba(255,255,255,.8); border-bottom-color: rgba(255,255,255,.1); }
.feat-body h3 {
  font-size: clamp(20px, 2vw, 28px);
  font-weight: 700; color: var(--text); line-height: 1.2; margin-bottom: 16px;
}
.feat-body p { font-size: 15px; color: var(--text-light); line-height: 1.75; margin-bottom: 12px; }
.feat-list { list-style: none; margin: 20px 0 28px; }
.feat-list li {
  padding: 10px 0 10px 20px; border-bottom: 1px solid var(--border);
  font-size: 15px; color: var(--text-light); position: relative;
}
.feat-list li::before { content: '—'; position: absolute; left: 0; color: var(--blue); font-weight: 700; }

/* ─── CARD ROW (2 cards side by side) ─── */
.cards-row {
  background: var(--bg-light);
  border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
}
.cards-row-inner {
  max-width: 1280px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  padding: 0;
}
.info-card {
  padding: 60px 70px;
  border-right: 1px solid var(--border);
}
.info-card:last-child { border-right: none; }
.info-card h4 {
  font-size: 20px; font-weight: 700; color: var(--text);
  margin-bottom: 14px; line-height: 1.3;
}
.info-card p { font-size: 15px; color: var(--text-light); line-height: 1.75; margin-bottom: 20px; }

/* ─── DOWNLOADS BANNER ─── */
.downloads-banner {
  background: var(--blue);
  padding: 28px 80px;
  display: flex; align-items: center; justify-content: space-between;
  max-width: none;
}
.downloads-banner p { color: white; font-size: 16px; font-weight: 600; display: flex; align-items: center; gap: 14px; }
.downloads-banner p span { font-size: 24px; }
.downloads-banner a {
  color: white; font-size: 14px; font-weight: 600;
  display: inline-flex; align-items: center; gap: 6px;
  text-decoration: none; border-bottom: 1px solid rgba(255,255,255,.4);
  padding-bottom: 2px;
}
.downloads-banner a:hover { border-bottom-color: white; }
.downloads-banner a::after { content: '→'; }

/* ─── BENEFITS ─── */
#beneficios { background: var(--white); border-top: 1px solid var(--border); }
.benefits-header { max-width: 1280px; margin: 0 auto; padding: 70px 80px 40px; }
.benefits-header h2 { margin-bottom: 0; }
.benefits-grid {
  max-width: 1280px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(5, 1fr);
  border-top: 1px solid var(--border);
  padding: 0 80px;
}
.benefit-item {
  padding: 40px 0 40px 0;
  border-right: 1px solid var(--border);
  padding-right: 30px; padding-left: 30px;
  text-align: center;
}
.benefit-item:first-child { padding-left: 0; }
.benefit-item:last-child { border-right: none; padding-right: 0; }
.benefit-icon-wrap {
  width: 64px; height: 64px; margin: 0 auto 16px;
  background: var(--bg-light);
  display: flex; align-items: center; justify-content: center;
}
.benefit-icon-wrap svg { width: 32px; height: 32px; stroke: var(--blue); fill: none; stroke-width: 1.5; }
.benefit-item h4 { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
.benefit-item p { font-size: 13px; color: var(--text-light); line-height: 1.6; }

/* ─── DIGITAL BANNER ─── */
.digital-banner {
  background: #1a2e48;
  padding: 60px 80px;
  text-align: center;
}
.digital-banner p {
  color: rgba(255,255,255,.65); font-size: 18px; font-weight: 300;
  letter-spacing: 0.5px;
}

/* ─── TESTIMONIAL ─── */
#testimonial {
  background: var(--white);
  border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
}
.testimonial-inner {
  max-width: 900px; margin: 0 auto; padding: 80px;
  text-align: center;
}
.testimonial-inner blockquote {
  font-size: clamp(20px, 2.5vw, 30px);
  font-weight: 300; color: var(--text); line-height: 1.5;
  font-style: italic; margin-bottom: 28px;
}
.testimonial-inner blockquote::before { content: '"'; font-size: 60px; color: var(--blue); line-height: 0; vertical-align: -20px; margin-right: 4px; }
.testimonial-inner blockquote::after  { content: '"'; font-size: 60px; color: var(--blue); line-height: 0; vertical-align: -20px; margin-left: 4px; }
.testimonial-author { font-size: 14px; color: var(--text-light); font-weight: 600; }
.testimonial-btn { margin-top: 32px; }

/* ─── CERTIFICATIONS ─── */
#certs { background: var(--bg-light); border-bottom: 1px solid var(--border); }
.certs-inner {
  max-width: 1280px; margin: 0 auto;
  padding: 60px 80px;
}
.certs-inner h3 { font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 36px; }
.certs-logos {
  display: flex; flex-wrap: wrap; gap: 32px; align-items: center;
}
.cert-logo {
  background: white; border: 1px solid var(--border);
  width: 110px; height: 70px;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; color: var(--text-light);
  text-align: center; letter-spacing: 0.5px; text-transform: uppercase;
  padding: 8px;
}

/* ─── TABS SECTION ─── */
#tabs-section { background: var(--white); }
.tabs-wrapper { max-width: 1280px; margin: 0 auto; padding: 80px; }
.tabs-nav {
  display: flex; border-bottom: 2px solid var(--border);
  margin-bottom: 0; gap: 0;
}
.tab-btn {
  padding: 14px 28px; font-size: 14px; font-weight: 600;
  color: var(--text-light); cursor: pointer; background: none; border: none;
  border-bottom: 3px solid transparent; margin-bottom: -2px;
  transition: color .2s, border-color .2s;
}
.tab-btn.active { color: var(--blue); border-bottom-color: var(--blue); }
.tab-btn:hover { color: var(--blue); }
.tab-panels { border: 1px solid var(--border); border-top: none; }
.tab-panel { display: none; }
.tab-panel.active { display: grid; grid-template-columns: 1fr 1fr; }
.tab-panel-body { padding: 60px 60px; display: flex; flex-direction: column; justify-content: center; }
.tab-panel-body h4 { font-size: 22px; font-weight: 700; color: var(--text); margin-bottom: 14px; line-height: 1.3; }
.tab-panel-body p { font-size: 15px; color: var(--text-light); line-height: 1.75; margin-bottom: 20px; }
.tab-panel-img { overflow: hidden; min-height: 340px; background: var(--bg-light); }
.tab-panel-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ─── CONTACT FOOTER ─── */
#contact-cta {
  background: var(--blue);
  padding: 80px;
  text-align: center;
}
#contact-cta h2 { color: white; font-size: clamp(24px, 3vw, 38px); margin-bottom: 12px; }
#contact-cta p { color: rgba(255,255,255,.75); font-size: 16px; margin-bottom: 32px; }
.btn-white {
  display: inline-block; background: white; color: var(--blue);
  padding: 13px 32px; font-weight: 700; font-size: 15px;
  text-decoration: none; transition: background .2s;
}
.btn-white:hover { background: #f0f4f8; }

/* ─── FOOTER ─── */
footer {
  background: var(--text); color: rgba(255,255,255,.6);
  padding: 60px 80px 30px;
}
.footer-top {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 60px; padding-bottom: 50px;
  border-bottom: 1px solid rgba(255,255,255,.1);
  margin-bottom: 28px;
}
.footer-brand .nav-logo-box { display: inline-block; margin-bottom: 14px; }
.footer-brand p { font-size: 13px; line-height: 1.7; color: rgba(255,255,255,.5); margin-bottom: 20px; }
.footer-socials { display: flex; gap: 10px; }
.social-icon {
  width: 34px; height: 34px; border: 1px solid rgba(255,255,255,.2);
  display: flex; align-items: center; justify-content: center;
  transition: border-color .2s;
}
.social-icon:hover { border-color: rgba(255,255,255,.6); }
.social-icon svg { width: 15px; height: 15px; fill: rgba(255,255,255,.6); }
.footer-col h5 {
  color: white; font-size: 13px; font-weight: 700;
  letter-spacing: 1px; text-transform: uppercase;
  margin-bottom: 16px;
}
.footer-col ul { list-style: none; }
.footer-col ul li { margin-bottom: 8px; }
.footer-col ul li a { font-size: 13px; color: rgba(255,255,255,.5); text-decoration: none; transition: color .2s; }
.footer-col ul li a:hover { color: white; }
.footer-contact-info p { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 6px; line-height: 1.6; }
.footer-contact-info a { color: rgba(255,255,255,.5); text-decoration: none; }
.footer-contact-info a:hover { color: white; }
.footer-bottom {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 12px;
}
.footer-legal { display: flex; gap: 20px; }
.footer-legal a { font-size: 12px; color: rgba(255,255,255,.35); text-decoration: none; }
.footer-legal a:hover { color: rgba(255,255,255,.7); }

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
  nav ul, .nav-langs { display: none; }
  #hero, .intro-inner, .feature-block, .cards-row-inner, .tab-panel.active, .footer-top { grid-template-columns: 1fr; }
  .section, .section-sm, .intro-inner, .downloads-banner, .benefits-header, .certs-inner, .tabs-wrapper, #contact-cta, footer { padding-left: 24px; padding-right: 24px; }
  .benefits-grid { grid-template-columns: repeat(2,1fr); padding: 0 24px; }
  .hero-left { padding: 50px 24px; }
  .feat-body { padding: 50px 24px; }
  .info-card { padding: 40px 24px; border-right: none; border-bottom: 1px solid var(--border); }
  .footer-bottom { flex-direction: column; gap: 12px; }
}
</style>
</head>
